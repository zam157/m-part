{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ESNext"],
    "paths": {
      "#shared/*": ["./shared/*"],
      "#server/*": ["./server/*"]
    }
  },
  "types": [
    "node"
  ],
  "include": [
    "./server/**/*.ts",
    "./test/server/**/*.ts",
    "./shared/**/*.ts"
  ]
}
