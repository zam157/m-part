{
  "extends": "../tsconfig.frontend.json",
  "compilerOptions": {
    "rootDir": "./"
  },
  "include": [
    "./**/*.ts",
    "./**/*.vue"
  ],
  "vueCompilerOptions": {
    "strictTemplates": true,
    "plugins": [
      "vue-router/volar/sfc-route-blocks",
      "vue-router/volar/sfc-typed-router"
    ]
  }
}
