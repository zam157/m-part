{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "paths": {
      "~/*": ["./client/*"],
      "#shared/*": ["./shared/*"]
    },
    "types": [
      "node",
      "vite/client",
      "vite-plugin-pwa/client"
    ]
  },
  "include": [
    "./test/client/**/*.ts",
    "./client/**/*.ts",
    "./client/**/*.vue"
  ],
  "vueCompilerOptions": {
    "strictTemplates": true,
    "plugins": [
      "vue-router/volar/sfc-route-blocks",
      {
        "name": "vue-router/volar/sfc-typed-router",
        "options": {
          "rootDir": "./client"
        }
      }
    ]
  }
}
